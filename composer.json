{
    "name": "openplain/laravel-flowfield",
    "description": "Cache-backed computed aggregate fields for Eloquent — inspired by Navision's FlowField concept.",
    "keywords": ["laravel", "eloquent", "flowfield", "cache", "aggregate", "computed", "navision", "sift"],
    "homepage": "https://github.com/openplain/laravel-flowfield",
    "license": "MIT",
    "authors": [
        {
            "name": "Openplain",
            "email": "hello@openplain.dev",
            "homepage": "https://openplain.dev"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/cache": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Openplain\\FlowField\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Openplain\\FlowField\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Openplain\\FlowField\\FlowFieldServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
